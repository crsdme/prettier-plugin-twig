{# Missing const between expression and autoplay = … + indented callback body #}
<script>
    const carousel = document.getElementById("carousel");

    const Autoplay =
        window.EmblaCarouselAutoplay?.default || window.EmblaCarouselAutoplay;
    const autoplay = Autoplay({
        delay: 3000,
        stopOnInteraction: false,
        stopOnMouseEnter: true,
    });

    const embla = EmblaCarousel(carousel, { loop: true }, [autoplay]);

    document
        .getElementById("carousel-prev")
        ?.addEventListener("click", () => embla.scrollPrev());
    document
        .getElementById("carousel-next")
        ?.addEventListener("click", () => embla.scrollNext());

    const dots = document
        .getElementById("carousel-dots")
        .querySelectorAll(".carousel-dot");
    const syncDots = () => {
        const i = embla.selectedScrollSnap();
        dots.forEach((dot, idx) => {
            dot.classList.toggle("bg-neutral-800", idx === i);
            dot.classList.toggle("bg-neutral-300", idx !== i);
        });
    };
    embla.on("select", syncDots);
    syncDots();
    dots.forEach((dot, idx) => {
        dot.addEventListener("click", () => embla.scrollTo(idx));
    });
</script>
